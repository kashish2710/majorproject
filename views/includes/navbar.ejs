
<style>
  .searchD {
   
    border-radius: 50px; /* smooth round corners */
  }

  .searchinput {
    padding: 0 2rem; /* wide padding reduced */
    width: 250px; /* reasonable default width */
    transition: width 0.3s ease;
  }

  .searchinput:focus {
    width: 350px; /* expand on focus */
  }

  .btn-search {
  
    border-radius: 50px;
    padding: 0.5rem 1.5rem;

  }
.btn-search{
  background: linear-gradient(to right, pink, #FFA07A, #fa9874);
  color: white;
}

  @media (max-width: 768px) {
    .searchinput {
        
      width: 150px;
    }
    .searchinput:focus {
      width: 200px;
    }
  }
/* For buttons like .cta-button, .host-btn, and the search button */
/* For buttons like .cta-button, .host-btn, and the search button */
.host-activity {
  width:15rem;
  background: linear-gradient(to right, pink , #FFA07A, #fa9874); /* Light Salmon to Coral */
  /* If you want even lighter: */
  /* background: linear-gradient(to right, #FFDAB9, #FFB6C1); */ /* Peach Puff to Light Pink */
  color: white !important; /* Keep text white for contrast */
  padding: 0.8rem 2rem;
  text-align: center;
  border-radius: 2rem;
  text-decoration: none;
  font-weight: bold;
  transition: all 0.3s ease;
  border: none;
  cursor: pointer;
  box-shadow: 0 4px 10px rgba(255, 160, 122, 0.4); /* Softer shadow matching the gradient */
  margin-right: 1rem;
}



</style>

