
<style>
  .searchD {
    border-radius: 50px; /* smooth round corners */
  }

  .searchinput {
    padding: 0 2rem; /* wide padding reduced */
    width: 250px; /* reasonable default width */
    transition: width 0.3s ease;
  }

  .searchinput:focus {
    width: 350px; /* expand on focus */
  }

  .btn-search {
    border-radius: 50px;
    padding: 0.5rem 1.5rem;
  }

  @media (max-width: 768px) {
    .searchinput {
      width: 150px;
    }
    .searchinput:focus {
      width: 200px;
    }
  }
  .host-activity {
  position: relative;
  display: inline-block;
  padding: 0.5rem 1rem;
  color: #fff !important;;
  background-color: #dc3545;
  border-radius: 1rem;
  overflow: hidden;
  transition: color 0.3s;
}

.host-activity::before {
  content: "";
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  border: 2px solid #fff;
  border-radius: 50%;
  opacity: 0.5;
  transform: scale(0);
  transition: transform 0.5s ease;
}

.host-activity:hover::before {
  transform: scale(1);
  animation: rotate-ring 1s linear infinite;
}

@keyframes rotate-ring {
  0% { transform: rotate(0deg) scale(1); }
  100% { transform: rotate(360deg) scale(1); }
}

</style>

<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <div class="container-fluid">
    <a class="navbar-brand" href="/"><i class="fa-regular fa-compass"></i></a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav">
        <a class="nav-link" href="/listings">Explore</a>
      </div>

      <!-- Search Form -->
      <div class="search ms-auto me-3">
        <form class="d-flex" role="search" action="/search" method="GET">
          <input class="form-control me-2 searchD searchinput" 
                 type="search" 
                 name="q" 
                 placeholder="Find your experience" 
                 aria-label="Search"/>
          <button class="btn btn-danger searchD btn-search" type="submit">Search</button>
        </form>
      </div>

      <div class="navbar-nav ms-auto">
<a class="nav-link host-activity" href="/listings/create" style="color: #fff;">Host Activity</a>

        <% if(!currUser) { %>
          <a class="nav-link active" aria-current="page" href="/signup"><b>SignUp</b></a>
          <a class="nav-link" href="/login"><b>Login</b></a>
        <% } %>
        <% if(currUser) { %>
          <a class="nav-link" href="/logout"><b>Logout</b></a>
        <% } %>
      </div>
    </div>
  </div>
</nav>
