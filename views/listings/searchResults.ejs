<% layout("layouts/boilerplate") %>
<% layout("layouts/boilerplate") %>

<div class="container mt-4">
  <h3>Search results for "<%= query %>"</h3>
  <div class="row">
    <% if(results.length === 0) { %>
      <p>No destinations found.</p>
    <% } else { %>
      <% results.forEach(listing => { %>
        <div class="col-md-4 mb-3">
          <div class="card">
            <% if(listing.image && listing.image.url) { %>
              <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.title %>">
            <% } else if(listing.images && listing.images.length > 0) { %>
              <img src="<%= listing.images[0].url %>" class="card-img-top" alt="<%= listing.title %>">
            <% } else { %>
              <img src="https://via.placeholder.com/400x300?text=No+Image" class="card-img-top" alt="No image">
            <% } %>

            <div class="card-body">
              <h5 class="card-title"><%= listing.title %></h5>
              <p class="card-text"><%= listing.location %></p>
              <a href="/listings/<%= listing._id %>" class="btn btn-primary">View</a>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>
